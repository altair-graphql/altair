{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "baseUrl": "src",
    "esModuleInterop": true,
    "emitDecoratorMetadata": false,
    "allowJs": true,
    "types": ["node", "chrome", "firefox-webext-browser"]
  },
  "files": ["src/polyfills.ts"],
  "include": ["**/*.spec.ts", "**/*.d.ts"]
}
