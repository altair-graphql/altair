  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.build.json && nest build",
    "env": "sync-dotenv",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "nest:generate:resource": "nest g resource",
    "nest:upgrade": "npx yarn-upgrade-all --ignore '^((?!@nestjs).)*$' --upgrade",
    "prebuild": "rimraf dist",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "rimraf dist && nest start --watch",
    "start:prod": "node dist/main",
    "start:prod:in-docker": "pnpm --dir ./node_modules/@altairgraphql/db prod:prestart && node dist/main",
    "migrate:e2e": "dotenv -e .env.e2e -- pnpm dlx prisma@5.16.2 migrate deploy --schema ../altair-db/prisma/schema.prisma",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "dotenv -e .env.e2e -- vitest run --config ./vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/altair-graphql/altair.git"
  },
  "pnpm": {
    "overrides": {
      "jsonwebtoken": "^9.0.3"
    }
  }
